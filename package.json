  "description": "<div align=\"center\"> \t<h1>Webpack simples</h1> \t<p>Configuração simple da webpack</b></p> </div>",
  "main": "app.js",
  "scripts": {
    "start": "npm run build:dev",
    "watch": "webpack --watch --progress",
    "build:dev": "webpack --progress --hide-modules --config=webpack.config.js",
    "build:prod": "webpack --env prod --mode production",
